# Work Server Authentication Token (generated by setup.sh)
WORK_SERVER_TOKEN=your-random-token-here

# Supabase connection for posting results back to sessions
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key

# Directory where approved scripts live
SCRIPTS_DIR=~/agent-onboard-scripts

# Server port (3002 since 3001 is the LLM proxy)
PORT=3002
